{
  "$schema": "./node_modules/knip/schema-jsonc.json",
  "ignore": ["src/api/openapi/**", "src/mocks/**"],
  "ignoreBinaries": ["openapiconfig.json", "actionlint", "zizmor"],
  "ignoreIssues": {
    "tools/oxlint-rules/*/*.ts": ["files"],
  },
  "vitest": {
    "entry": ["vitest.globalSetup.ts", "vitest.setup.ts"],
  },
}
