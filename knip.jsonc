{
  "$schema": "./node_modules/knip/schema-jsonc.json",
  "ignore": ["scripts/**", "src/**/openapi/**", "src/mocks/**", "tools/**"],
  "ignoreBinaries": ["openapiconfig.json"],
  "tailwind": {
    "entry": ["src/lib/styles/globals.css"],
  },
  "vitest": {
    "entry": [
      "**/*.{test,spec}.{ts,tsx}",
      "vitest.globalSetup.ts",
      "vitest.setup.ts",
    ],
  },
}
