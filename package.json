{
  "name": "nextjs-boilerplate",
  "private": true,
  "type": "module",
  "scripts": {
    "prepare": "lefthook install || true",
    "postinstall": "bash scripts/postinstall.sh",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "check": "pnpm lint && pnpm fmt && pnpm knip",
    "fix": "pnpm lint:fix && pnpm fmt:fix",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "lint:workflows": "actionlint -color && zizmor .github/",
    "fmt": "oxfmt --check .",
    "fmt:fix": "oxfmt --write .",
    "knip": "knip && knip --production",
    "test": "vitest run",
    "test:unit": "vitest run --project=unit",
    "test:oxlint-rules": "vitest run --project=oxlint-rules",
    "test:update": "vitest run --update",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage",
    "analyze": "next experimental-analyze",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "generate-api": "pnpm dlx @openapitools/openapi-generator-cli generate -i openapi.yml -g typescript-fetch -o ./src/api/openapi -c openapiconfig.json --openapi-normalizer SET_TAGS_FOR_ALL_OPERATIONS=default",
    "generate-api:clean": "rm -rf src/api/openapi && pnpm generate-api",
    "generate-mock": "msw-auto-mock openapi.yml -o ./src/mocks --typescript --base-url https://jsonplaceholder.typicode.com && sed -i '' 's|from \"@faker-js/faker\"|from \"@faker-js/faker/locale/ja\"|' ./src/mocks/handlers.ts"
  },
  "dependencies": {
    "@hookform/resolvers": "5.2.2",
    "@radix-ui/react-dialog": "1.1.15",
    "@radix-ui/react-icons": "1.3.2",
    "@radix-ui/react-slot": "1.2.4",
    "@tanstack/react-query": "5.100.10",
    "@tanstack/react-query-devtools": "5.100.10",
    "next": "16.2.6",
    "nuqs": "2.8.9",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-error-boundary": "6.1.1",
    "react-hook-form": "8.0.0-beta.1",
    "sonner": "2.0.7",
    "tailwind-merge": "3.6.0",
    "tailwind-variants": "3.2.2",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@babel/core": "7.29.0",
    "@faker-js/faker": "10.4.0",
    "@next/env": "16.2.6",
    "@oxlint/plugins": "1.65.0",
    "@rolldown/plugin-babel": "0.2.3",
    "@storybook/addon-a11y": "10.4.0",
    "@storybook/addon-docs": "10.4.0",
    "@storybook/addon-mcp": "0.6.0",
    "@storybook/addon-vitest": "10.4.0",
    "@storybook/nextjs-vite": "10.4.0",
    "@tailwindcss/postcss": "4.3.0",
    "@tanstack/eslint-plugin-query": "5.100.10",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/babel__core": "7.20.5",
    "@types/node": "24.12.4",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "@vitest/browser-playwright": "4.1.6",
    "@vitest/coverage-v8": "4.1.6",
    "axe-core": "4.11.4",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-storybook": "10.4.0",
    "happy-dom": "20.9.0",
    "knip": "6.14.1",
    "lefthook": "2.1.6",
    "msw": "2.14.6",
    "msw-auto-mock": "0.32.1",
    "msw-storybook-addon": "2.0.7",
    "oxfmt": "0.50.0",
    "oxlint": "1.65.0",
    "oxlint-tsgolint": "0.22.1",
    "playwright": "1.60.0",
    "remark-gfm": "4.0.1",
    "storybook": "10.4.0",
    "tailwindcss": "4.3.0",
    "typescript": "6.0.3",
    "vite": "8.0.12",
    "vitest": "4.1.6"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@11.1.1",
  "msw": {
    "workerDirectory": "public"
  }
}
